# Server
PORT=3000
NODE_ENV=development

# Database (points at the identity schema created by database/migrations)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nahu_platform?schema=identity"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
OTP_EXPIRES_MINUTES=10

# Africa's Talking (SMS OTP delivery)
# Leave AT_API_KEY / AT_USERNAME unset in local dev — the DEV_OTP fallback
# (123456) works without them. Required once NODE_ENV=production.
AT_API_KEY=
AT_USERNAME=
# Only set once a real Sender ID has been registered and approved with AT.
AT_SENDER_ID=

# Advisory module (AI-powered farmer advice, Claude API)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

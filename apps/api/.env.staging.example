# Staging environment template — set these in Railway (staging environment → nahu-api service)

NODE_ENV=production
PORT=3000

# Link from Railway Postgres service (Variables → Reference)
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Generate: openssl rand -base64 48
JWT_SECRET=

JWT_EXPIRES_IN=7d
OTP_EXPIRES_MINUTES=10

# Staging testing only — allows OTP 123456 and returns dev_otp in request-otp response
# Workforce/admin users are still blocked from OTP authentication.
OTP_DEV_BYPASS=true

# Required in staging/production so uploaded listing photo URLs are reachable
PUBLIC_API_URL=https://nahu-api-staging.up.railway.app

# A1 Admin Portal — required when NODE_ENV=production
# Generate: openssl rand -hex 32
ADMIN_MFA_ENCRYPTION_KEY=
ADMIN_ACCESS_TOKEN_TTL=15m
ADMIN_REFRESH_ABSOLUTE_HOURS=12
ADMIN_REFRESH_IDLE_MINUTES=30
ADMIN_INVITATION_TTL_HOURS=72

# Optional — OTP SMS
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=

# Optional — advisory module
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Comma-separated origins — include Admin Web staging origin for credentialed admin traffic
# CORS_ORIGINS=https://nahu-admin-staging.up.railway.app
CORS_ORIGINS=

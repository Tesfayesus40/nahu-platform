# Staging environment template — set these in Railway (staging environment → nahu-api service)

NODE_ENV=production
PORT=3000

# Link from Railway Postgres service (Variables → Reference)
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Generate: openssl rand -base64 48
JWT_SECRET=

JWT_EXPIRES_IN=7d
OTP_EXPIRES_MINUTES=10

# Staging testing only — allows OTP 123456 and returns dev_otp in request-otp response
OTP_DEV_BYPASS=true

# Required in staging/production so uploaded listing photo URLs are reachable
PUBLIC_API_URL=https://nahu-api-staging.up.railway.app

# Optional — OTP dev bypass is disabled when NODE_ENV=production
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=

# Optional — advisory module
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Comma-separated origins for Expo web / admin (optional)
# CORS_ORIGINS=

// Nahu Platform — Prisma schema for the Identity module
// This maps 1:1 onto database/migrations/001..009_identity_*.sql
// Do not run `prisma migrate dev` against a database that already has these
// tables created by the raw SQL migrations — use `prisma db pull` to confirm
// drift, or `prisma migrate resolve` to mark them as applied.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["identity", "catalog", "marketplace", "orders", "farms", "inventory", "warehouse", "audit", "ops"]
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  LOCKED
  DEACTIVATED

  @@schema("identity")
  @@map("user_status")
}

model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName          String?   @map("first_name") @db.VarChar(100)
  middleName         String?   @map("middle_name") @db.VarChar(100)
  lastName           String?   @map("last_name") @db.VarChar(100)
  phone              String    @unique @db.VarChar(25)
  email              String?   @unique @db.VarChar(255)
  preferredLanguage  String    @default("en") @map("preferred_language") @db.Char(2)
  status             UserStatus @default(PENDING)
  phoneVerified      Boolean   @default(false) @map("phone_verified")
  emailVerified      Boolean   @default(false) @map("email_verified")
  authzVersion       Int       @default(1) @map("authz_version")
  mustResetPassword  Boolean   @default(false) @map("must_reset_password")
  mfaRequired        Boolean   @default(false) @map("mfa_required")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  credential         Credential?
  userRoles          UserRole[]
  userOrganizations  UserOrganization[]
  rolesAssigned      UserRole[]        @relation("AssignedByUser")
  permissionsGranted RolePermission[] @relation("GrantedByUser")
  farmerProfile      FarmerProfile?
  buyerOrders        Order[]           @relation("BuyerOrders")
  adminInvitationsReceived AdminInvitation[] @relation("InvitationInvitee")
  adminInvitationsSent     AdminInvitation[] @relation("InvitationInviter")
  mfaFactors         MfaFactor[]
  mfaRecoveryCodes   MfaRecoveryCode[]
  adminSessions      AdminSession[]

  @@map("users")
  @@schema("identity")
}

model Credential {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String    @unique @map("user_id") @db.Uuid
  passwordHash         String?   @map("password_hash")
  passwordChangedAt    DateTime? @map("password_changed_at") @db.Timestamptz
  lastLoginAt          DateTime? @map("last_login_at") @db.Timestamptz
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts") @db.SmallInt
  lockedUntil          DateTime? @map("locked_until") @db.Timestamptz
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credentials")
  @@schema("identity")
}

model Role {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String   @unique @db.VarChar(50)
  displayName      String   @map("display_name") @db.VarChar(100)
  description      String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz

  userRoles        UserRole[]
  rolePermissions  RolePermission[]

  @@map("roles")
  @@schema("identity")
}

model Permission {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String   @unique @db.VarChar(100)
  displayName      String   @map("display_name") @db.VarChar(150)
  description      String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz

  rolePermissions  RolePermission[]

  @@map("permissions")
  @@schema("identity")
}

model UserRole {
  userId      String   @map("user_id") @db.Uuid
  roleId      String   @map("role_id") @db.Uuid
  assignedAt  DateTime @default(now()) @map("assigned_at") @db.Timestamptz
  assignedBy  String?  @map("assigned_by") @db.Uuid

  user            User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedByUser  User? @relation("AssignedByUser", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("identity")
}

model RolePermission {
  roleId        String   @map("role_id") @db.Uuid
  permissionId  String   @map("permission_id") @db.Uuid
  grantedAt     DateTime @default(now()) @map("granted_at") @db.Timestamptz
  grantedBy     String?  @map("granted_by") @db.Uuid

  role            Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission      Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedByUser   User?       @relation("GrantedByUser", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("identity")
}

model Organization {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String    @unique @db.VarChar(50)
  name               String    @db.VarChar(255)
  description        String?
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  userOrganizations  UserOrganization[]

  @@map("organizations")
  @@schema("identity")
}

model UserOrganization {
  userId          String   @map("user_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  positionTitle   String?  @map("position_title") @db.VarChar(100)
  joinedAt        DateTime @default(now()) @map("joined_at") @db.Timestamptz
  isPrimary       Boolean  @default(false) @map("is_primary")

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
  @@map("user_organizations")
  @@schema("identity")
}

model OtpCode {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone      String   @db.VarChar(25)
  code       String   @db.VarChar(6)
  used       Boolean  @default(false)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([phone])
  @@map("otp_codes")
  @@schema("identity")
}

model AdminInvitation {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @db.VarChar(255)
  phone         String?   @db.VarChar(25)
  invitedUserId String?   @map("invited_user_id") @db.Uuid
  roleCodes     String[]  @map("role_codes")
  tokenHash     String    @unique @map("token_hash")
  invitedBy     String    @map("invited_by") @db.Uuid
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz
  acceptedAt    DateTime? @map("accepted_at") @db.Timestamptz
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  invitedUser   User?     @relation("InvitationInvitee", fields: [invitedUserId], references: [id], onDelete: SetNull)
  invitedByUser User      @relation("InvitationInviter", fields: [invitedBy], references: [id], onDelete: Restrict)

  @@index([email])
  @@map("admin_invitations")
  @@schema("identity")
}

// MFA type is VARCHAR + CHECK in identity/015 (not a Postgres enum).
// Keep as String so Prisma does not cast to a missing identity.mfa_factor_type.
model MfaFactor {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  type            String    @default("TOTP") @db.VarChar(20)
  label           String?   @db.VarChar(100)
  secretEncrypted String    @map("secret_encrypted")
  verifiedAt      DateTime? @map("verified_at") @db.Timestamptz
  disabledAt      DateTime? @map("disabled_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_factors")
  @@schema("identity")
}

model MfaRecoveryCode {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_recovery_codes")
  @@schema("identity")
}

model AdminSession {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  refreshTokenHash    String    @map("refresh_token_hash")
  authzVersionAtIssue Int       @map("authz_version_at_issue")
  ip                  String?   @db.VarChar(64)
  userAgent           String?   @map("user_agent") @db.VarChar(512)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  lastSeenAt          DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz
  absoluteExpiresAt   DateTime  @map("absolute_expires_at") @db.Timestamptz
  idleExpiresAt       DateTime  @map("idle_expires_at") @db.Timestamptz
  revokedAt           DateTime? @map("revoked_at") @db.Timestamptz
  revokeReason        String?   @map("revoke_reason") @db.VarChar(100)
  replacedBySessionId String?   @map("replaced_by_session_id") @db.Uuid
  reauthenticatedAt   DateTime? @map("reauthenticated_at") @db.Timestamptz

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy          AdminSession? @relation("SessionReplacement", fields: [replacedBySessionId], references: [id], onDelete: SetNull)
  replaces            AdminSession[] @relation("SessionReplacement")

  @@index([userId])
  @@index([refreshTokenHash])
  @@map("admin_sessions")
  @@schema("identity")
}

// Outcome is VARCHAR + CHECK in audit/002 (not a Postgres enum).
// Keep as String so Prisma does not cast to a missing audit.audit_outcome.
model AuditEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  occurredAt     DateTime @default(now()) @map("occurred_at") @db.Timestamptz
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  actorSessionId String?  @map("actor_session_id") @db.Uuid
  permissionCode String?  @map("permission_code") @db.VarChar(100)
  action         String   @db.VarChar(100)
  targetType     String?  @map("target_type") @db.VarChar(100)
  targetId       String?  @map("target_id") @db.VarChar(100)
  requestId      String?  @map("request_id") @db.VarChar(100)
  reason         String?
  outcome        String   @db.VarChar(20)
  beforeJson     Json?    @map("before_json")
  afterJson      Json?    @map("after_json")
  ip             String?  @db.VarChar(64)
  userAgent      String?  @map("user_agent") @db.VarChar(512)
  metadataJson   Json?    @map("metadata_json")

  @@index([occurredAt])
  @@index([actorUserId])
  @@index([action])
  @@map("events")
  @@schema("audit")
}

model FeatureFlag {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String    @unique @db.VarChar(100)
  displayName     String    @map("display_name") @db.VarChar(200)
  description     String?
  enabled         Boolean   @default(false)
  updatedByUserId String?   @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@index([enabled])
  @@map("feature_flags")
  @@schema("ops")
}

// ============================================================================
// Catalog module (Phase 2–3)
// Maps database/migrations/catalog/001..008_catalog_*.sql
// ============================================================================

model Category {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String    @unique @db.VarChar(50)
  nameEn        String    @map("name_en") @db.VarChar(100)
  nameAm        String    @map("name_am") @db.VarChar(100)
  descriptionEn String?   @map("description_en")
  descriptionAm String?   @map("description_am")
  isActive      Boolean   @default(false) @map("is_active")
  sortOrder     Int       @default(0) @map("sort_order") @db.SmallInt
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  products      Product[]
  listings      Listing[]

  @@index([isActive])
  @@map("categories")
  @@schema("catalog")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  COMING_SOON
  DISCONTINUED

  @@schema("catalog")
  @@map("product_status")
}

model Unit {
  code      String    @id @db.VarChar(20)
  nameEn    String    @map("name_en") @db.VarChar(50)
  nameAm    String    @map("name_am") @db.VarChar(50)
  dimension String    @db.VarChar(20)
  sortOrder Int       @default(0) @map("sort_order") @db.SmallInt

  products            Product[]
  listings            Listing[]
  orders              Order[]
  originCertificates  OriginCertificate[]
  conversionsFrom     UnitConversion[] @relation("ConversionFrom")
  conversionsTo       UnitConversion[] @relation("ConversionTo")
  stockLots           StockLot[]
  stockMovements      StockMovement[]
  reservations        Reservation[]
  storageSites        StorageSite[]
  croppingCycleLines  CroppingCycleLine[]
  harvestLines        HarvestLine[]
  farmActivities      FarmActivity[]

  @@map("units")
  @@schema("catalog")
}

model UnitConversion {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fromUnitCode String  @map("from_unit_code") @db.VarChar(20)
  toUnitCode   String  @map("to_unit_code") @db.VarChar(20)
  factor       Decimal @db.Decimal(18, 6)

  fromUnit     Unit    @relation("ConversionFrom", fields: [fromUnitCode], references: [code], onDelete: Restrict)
  toUnit       Unit    @relation("ConversionTo", fields: [toUnitCode], references: [code], onDelete: Restrict)

  @@unique([fromUnitCode, toUnitCode])
  @@map("unit_conversions")
  @@schema("catalog")
}

model Product {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId       String        @map("category_id") @db.Uuid
  code             String        @unique @db.VarChar(80)
  nameEn           String        @map("name_en") @db.VarChar(150)
  nameAm           String        @map("name_am") @db.VarChar(150)
  descriptionEn    String?       @map("description_en")
  descriptionAm    String?       @map("description_am")
  defaultUnitCode  String        @map("default_unit_code") @db.VarChar(20)
  status           ProductStatus @default(INACTIVE)
  isDefault        Boolean       @default(false) @map("is_default")
  sortOrder        Int           @default(0) @map("sort_order") @db.SmallInt
  attributesSchema Json?         @map("attributes_schema")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime      @default(now()) @map("updated_at") @db.Timestamptz

  category         Category           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  defaultUnit      Unit               @relation(fields: [defaultUnitCode], references: [code], onDelete: Restrict)
  varieties        ProductVariety[]
  translations     ProductTranslation[]
  listings           Listing[]
  stockLots          StockLot[]
  croppingCycleLines CroppingCycleLine[]
  harvestLines       HarvestLine[]
  farmActivities     FarmActivity[]

  @@index([categoryId])
  @@index([status])
  @@map("products")
  @@schema("catalog")
}

model ProductVariety {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  code      String   @db.VarChar(80)
  nameEn    String   @map("name_en") @db.VarChar(150)
  nameAm    String   @map("name_am") @db.VarChar(150)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockLots          StockLot[]
  croppingCycleLines CroppingCycleLine[]
  harvestLines       HarvestLine[]

  @@unique([productId, code])
  @@index([productId])
  @@map("product_varieties")
  @@schema("catalog")
}

model ProductTranslation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  locale      String   @db.VarChar(15)
  name        String   @db.VarChar(150)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([locale])
  @@map("product_translations")
  @@schema("catalog")
}

// ============================================================================
// Marketplace module (Package 003)
// Maps database/migrations/marketplace/001..004_marketplace_*.sql
// ============================================================================

enum ProcessMethod {
  WASHED
  NATURAL
  HONEY
  SEMI_WASHED
  HULLED
  ANAEROBIC
  CARBONIC_MACERATION

  @@schema("marketplace")
  @@map("process_method")
}

enum CoffeeGrade {
  GRADE_1
  GRADE_2
  GRADE_3
  GRADE_4
  GRADE_5
  GRADE_6
  GRADE_7
  GRADE_8
  GRADE_9
  GRADE_UNKNOWN

  @@schema("marketplace")
  @@map("coffee_grade")
}

enum ListingStatus {
  ACTIVE
  RESERVED
  SOLD
  CANCELLED

  @@schema("marketplace")
  @@map("listing_status")
}

model Cooperative {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String    @db.VarChar(200)
  unionName      String?   @map("union_name") @db.VarChar(200)
  region         String    @db.VarChar(100)
  zone           String?   @db.VarChar(100)
  licenseNumber  String?   @map("license_number") @db.VarChar(50)
  verified       Boolean   @default(false)
  verificationStatus String @default("PENDING") @map("verification_status") @db.VarChar(20)
  verificationNotes String? @map("verification_notes") @db.VarChar(500)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  farmerProfiles   FarmerProfile[]
  farms            Farm[]
  farmParties      FarmParty[]
  storageSites     StorageSite[]
  warehouseParties WarehouseParty[]

  @@map("cooperatives")
  @@schema("marketplace")
}

model FarmerProfile {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String    @unique @map("user_id") @db.Uuid
  cooperativeId      String?   @map("cooperative_id") @db.Uuid
  region             String    @db.VarChar(100)
  zone               String?   @db.VarChar(100)
  woreda             String?   @db.VarChar(100)
  altitudeM          Decimal?  @map("altitude_m") @db.Decimal(6, 1)
  farmSizeHa         Decimal?  @map("farm_size_ha") @db.Decimal(6, 2)
  primaryLanguage    String    @default("am") @map("primary_language") @db.VarChar(200)
  verified           Boolean   @default(false)
  verificationStatus String    @default("PENDING") @map("verification_status") @db.VarChar(20)
  verificationNotes  String?   @map("verification_notes") @db.VarChar(500)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cooperative        Cooperative?  @relation(fields: [cooperativeId], references: [id], onDelete: SetNull)
  listings           Listing[]
  orders             Order[]       @relation("FarmerOrders")
  farmParties        FarmParty[]
  warehouseParties   WarehouseParty[]

  @@map("farmer_profiles")
  @@schema("marketplace")
}

// Participant verification workflow (A3). Status/decision stored as VARCHAR + CHECK in SQL.
model VerificationCase {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subjectType        String    @map("subject_type") @db.VarChar(20)
  subjectId          String    @map("subject_id") @db.Uuid
  status             String    @default("PENDING") @db.VarChar(20)
  displayName        String?   @map("display_name") @db.VarChar(255)
  region             String?   @db.VarChar(100)
  reviewerUserId     String?   @map("reviewer_user_id") @db.Uuid
  reviewerNotes      String?   @map("reviewer_notes")
  infoRequestMessage String?   @map("info_request_message")
  submittedAt        DateTime  @default(now()) @map("submitted_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz
  decidedAt          DateTime? @map("decided_at") @db.Timestamptz

  decisions          VerificationDecision[]
  documents          VerificationDocument[]

  @@unique([subjectType, subjectId])
  @@index([status])
  @@index([subjectType, status])
  @@index([submittedAt])
  @@map("verification_cases")
  @@schema("marketplace")
}

model VerificationDecision {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId      String   @map("case_id") @db.Uuid
  decision    String   @db.VarChar(20)
  fromStatus  String?  @map("from_status") @db.VarChar(20)
  toStatus    String   @map("to_status") @db.VarChar(20)
  reason      String?
  notes       String?
  actorUserId String   @map("actor_user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  case        VerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("verification_decisions")
  @@schema("marketplace")
}

model VerificationDocument {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId           String   @map("case_id") @db.Uuid
  label            String   @db.VarChar(200)
  fileUrl          String   @map("file_url")
  contentType      String?  @map("content_type") @db.VarChar(100)
  uploadedByUserId String?  @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  case             VerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("verification_documents")
  @@schema("marketplace")
}

model Listing {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmerId       String        @map("farmer_id") @db.Uuid
  categoryId     String?       @map("category_id") @db.Uuid
  productId      String?       @map("product_id") @db.Uuid
  stockLotId     String?       @map("stock_lot_id") @db.Uuid
  farmId         String?       @map("farm_id") @db.Uuid
  region         String        @db.VarChar(100)
  regionEn       String?       @map("region_en") @db.VarChar(100)
  woreda         String?       @db.VarChar(100)
  washingStation String?       @map("washing_station") @db.VarChar(150)
  cooperative    String?       @db.VarChar(200)
  processMethod  ProcessMethod @map("process_method")
  grade          CoffeeGrade
  variety        String?       @db.VarChar(100)
  quantityKg     Decimal       @map("quantity_kg") @db.Decimal(8, 2)
  pricePerKg     Decimal       @map("price_per_kg") @db.Decimal(8, 2)
  /// G1 canonical quantity — dual-written with quantityKg for KG/coffee legacy.
  quantity       Decimal?      @db.Decimal(12, 3)
  unitCode       String?       @map("unit_code") @db.VarChar(20)
  pricePerUnit   Decimal?      @map("price_per_unit") @db.Decimal(12, 2)
  packagingLabel String?       @map("packaging_label") @db.VarChar(100)
  packagingQuantity Decimal?   @map("packaging_quantity") @db.Decimal(12, 3)
  harvestDate    DateTime      @map("harvest_date") @db.Date
  altitudeM      Decimal?      @map("altitude_m") @db.Decimal(6, 1)
  cupScore       Decimal?      @map("cup_score") @db.Decimal(4, 1)
  photoUrls      String[]      @default([]) @map("photo_urls")
  status         ListingStatus @default(ACTIVE)
  moderationStatus String      @default("APPROVED") @map("moderation_status") @db.VarChar(20)
  moderationNotes  String?     @map("moderation_notes")
  moderatedAt      DateTime?   @map("moderated_at") @db.Timestamptz
  moderatedByUserId String?    @map("moderated_by_user_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @default(now()) @map("updated_at") @db.Timestamptz

  farmer         FarmerProfile @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  category       Category?     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  product        Product?      @relation(fields: [productId], references: [id], onDelete: Restrict)
  unit           Unit?         @relation(fields: [unitCode], references: [code], onDelete: Restrict)
  stockLot       StockLot?     @relation(fields: [stockLotId], references: [id], onDelete: SetNull)
  farm           Farm?         @relation(fields: [farmId], references: [id], onDelete: SetNull)
  orders         Order[]
  reservations   Reservation[]
  moderationDecisions ListingModerationDecision[]

  @@index([region])
  @@index([grade])
  @@index([status])
  @@index([moderationStatus])
  @@index([categoryId])
  @@index([productId])
  @@index([stockLotId])
  @@index([farmId])
  @@index([unitCode])
  @@map("listings")
  @@schema("marketplace")
}

model ListingModerationDecision {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId   String   @map("listing_id") @db.Uuid
  decision    String   @db.VarChar(20)

// ============================================================================
// Inventory module (Phase 4.2)
// Maps database/migrations/inventory/001..005 + catalog/009_unit_conversions
// ============================================================================

enum LotStatus {
  RECEIVED
  AVAILABLE
  RESERVED
  QUARANTINE
  DAMAGED
  EXPIRED
  SOLD
  DEPLETED
  CANCELLED

  @@schema("inventory")
  @@map("lot_status")
}

enum MovementType {
  RECEIVE
  ADJUST_IN
  ADJUST_OUT
  TRANSFER_OUT
  TRANSFER_IN
  RESERVE
  RELEASE
  DISPATCH
  LOSS
  RETURN
  RELOCATE

  @@schema("inventory")
  @@map("movement_type")
}

enum LotSourceType {
  HARVEST
  PURCHASE
  TRANSFER_IN
  ADJUSTMENT_OPENING
  OTHER

  @@schema("inventory")
  @@map("lot_source_type")
}

model StockLot {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lotCode          String        @map("lot_code") @db.VarChar(64)
  productId        String        @map("product_id") @db.Uuid
  productVarietyId String?       @map("product_variety_id") @db.Uuid
  farmId           String        @map("farm_id") @db.Uuid
  plotId           String?       @map("plot_id") @db.Uuid
  storageSiteId    String?       @map("storage_site_id") @db.Uuid
  storageLabel     String?       @map("storage_label") @db.VarChar(150)
  unitCode         String        @map("unit_code") @db.VarChar(20)
  quantityOnHand   Decimal       @default(0) @map("quantity_on_hand") @db.Decimal(14, 3)
  quantityReserved Decimal       @default(0) @map("quantity_reserved") @db.Decimal(14, 3)
  status           LotStatus     @default(AVAILABLE)
  sourceType       LotSourceType @default(HARVEST) @map("source_type")
  harvestDate      DateTime?     @map("harvest_date") @db.Date
  receivedAt       DateTime      @default(now()) @map("received_at") @db.Timestamptz
  expiresOn        DateTime?     @map("expires_on") @db.Date
  qualityNote      String?       @map("quality_note")
  externalRef      String?       @map("external_ref") @db.VarChar(100)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime      @default(now()) @map("updated_at") @db.Timestamptz

  product          Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  productVariety   ProductVariety? @relation(fields: [productVarietyId], references: [id], onDelete: SetNull)
  farm             Farm            @relation(fields: [farmId], references: [id], onDelete: Restrict)
  plot             Plot?           @relation(fields: [plotId], references: [id], onDelete: SetNull)
  storageSite      StorageSite?    @relation(fields: [storageSiteId], references: [id], onDelete: SetNull)
  unit             Unit            @relation(fields: [unitCode], references: [code], onDelete: Restrict)
  movements        StockMovement[]
  reservations     Reservation[]
  listings         Listing[]

  @@unique([farmId, lotCode])
  @@index([farmId])
  @@index([productId])
  @@index([status])
  @@index([storageSiteId])
  @@map("stock_lots")
  @@schema("inventory")
}

model StockMovement {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lotId                 String       @map("lot_id") @db.Uuid
  movementType          MovementType @map("movement_type")
  qty                   Decimal      @db.Decimal(14, 3)
  unitCode              String       @map("unit_code") @db.VarChar(20)
  qtyInLotUnit          Decimal      @map("qty_in_lot_unit") @db.Decimal(14, 3)
  reason                String?      @db.VarChar(500)
  actorUserId           String?      @map("actor_user_id") @db.Uuid
  listingId             String?      @map("listing_id") @db.Uuid
  orderId               String?      @map("order_id") @db.Uuid
  counterpartMovementId String?      @map("counterpart_movement_id") @db.Uuid
  fromStorageSiteId     String?      @map("from_storage_site_id") @db.Uuid
  toStorageSiteId       String?      @map("to_storage_site_id") @db.Uuid
  metadata              Json?
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz

  lot                   StockLot      @relation(fields: [lotId], references: [id], onDelete: Restrict)
  unit                  Unit          @relation(fields: [unitCode], references: [code], onDelete: Restrict)
  counterpart           StockMovement? @relation("MovementCounterpart", fields: [counterpartMovementId], references: [id], onDelete: SetNull)
  counterparts          StockMovement[] @relation("MovementCounterpart")
  fromStorageSite       StorageSite?  @relation("MovementFromSite", fields: [fromStorageSiteId], references: [id], onDelete: SetNull)
  toStorageSite         StorageSite?  @relation("MovementToSite", fields: [toStorageSiteId], references: [id], onDelete: SetNull)

  @@index([lotId])
  @@index([createdAt])
  @@map("stock_movements")
  @@schema("inventory")
}


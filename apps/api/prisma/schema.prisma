  nameAm            String?    @map("name_am") @db.VarChar(150)
  status            FarmStatus @default(ACTIVE)
  sizeHa            Decimal?   @map("size_ha") @db.Decimal(10, 2)
  centroidLat       Decimal?   @map("centroid_lat") @db.Decimal(9, 6)
  centroidLng       Decimal?   @map("centroid_lng") @db.Decimal(9, 6)
  boundaryGeojson   Json?      @map("boundary_geojson")
  boundarySource    String?    @map("boundary_source") @db.VarChar(40)
  boundaryUpdatedAt DateTime?  @map("boundary_updated_at") @db.Timestamptz
  notes             String?
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime   @default(now()) @map("updated_at") @db.Timestamptz

  plot              Plot             @relation(fields: [plotId], references: [id], onDelete: Cascade)
  productionUnits   ProductionUnit[]

  @@index([plotId])
  @@map("fields")
  @@schema("farms")
}

model ProductionUnit {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmId          String             @map("farm_id") @db.Uuid
  plotId          String?            @map("plot_id") @db.Uuid
  fieldId         String?            @map("field_id") @db.Uuid
  code            String?            @db.VarChar(40)
  name            String             @db.VarChar(150)
  kind            ProductionUnitKind @default(GENERIC)
  status          FarmStatus         @default(ACTIVE)
  sizeHa          Decimal?           @map("size_ha") @db.Decimal(10, 2)
  centroidLat     Decimal?           @map("centroid_lat") @db.Decimal(9, 6)
  centroidLng     Decimal?           @map("centroid_lng") @db.Decimal(9, 6)
  boundaryGeojson Json?              @map("boundary_geojson")
  notes           String?
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime           @default(now()) @map("updated_at") @db.Timestamptz

  farm            Farm               @relation(fields: [farmId], references: [id], onDelete: Cascade)

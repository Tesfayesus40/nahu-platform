  unit             Unit           @relation(fields: [unitCode], references: [code], onDelete: Restrict)
  stockLots        StockLot[]
  harvestLines     HarvestLine[]

  @@unique([cycleId, productId])
  @@index([productId])
  @@index([cycleId])
  @@map("cropping_cycle_lines")
  @@schema("farms")
}

model HarvestSession {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmId           String               @map("farm_id") @db.Uuid
  plotId           String?              @map("plot_id") @db.Uuid
  croppingCycleId  String?              @map("cropping_cycle_id") @db.Uuid
  harvestedOn      DateTime             @map("harvested_on") @db.Date
  harvestedAt      DateTime?            @map("harvested_at") @db.Timestamptz
  status           HarvestSessionStatus @default(DRAFT)
  notes            String?
  crewCount        Int?                 @map("crew_count")
  photoUrls        String[]             @default([]) @map("photo_urls")
  postedAt         DateTime?            @map("posted_at") @db.Timestamptz
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime             @default(now()) @map("updated_at") @db.Timestamptz

  farm             Farm                 @relation(fields: [farmId], references: [id], onDelete: Restrict)
  plot             Plot?                @relation(fields: [plotId], references: [id], onDelete: SetNull)
  croppingCycle    CroppingCycle?       @relation(fields: [croppingCycleId], references: [id], onDelete: SetNull)
  lines            HarvestLine[]
  farmActivities   FarmActivity[]

  @@index([farmId])
  @@index([status])
  @@index([croppingCycleId])
  @@index([farmId, harvestedOn])
  @@map("harvest_sessions")
  @@schema("farms")
}

model HarvestLine {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId            String    @map("session_id") @db.Uuid
  productId            String    @map("product_id") @db.Uuid
  productVarietyId     String?   @map("product_variety_id") @db.Uuid

// Nahu Platform — Prisma schema for the Identity module
// This maps 1:1 onto database/migrations/001..009_identity_*.sql
// Do not run `prisma migrate dev` against a database that already has these
// tables created by the raw SQL migrations — use `prisma db pull` to confirm
// drift, or `prisma migrate resolve` to mark them as applied.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["identity", "catalog", "marketplace", "orders", "farms", "inventory", "warehouse"]
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  LOCKED
  DEACTIVATED

  @@schema("identity")
  @@map("user_status")
}

model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName          String?   @map("first_name") @db.VarChar(100)
  middleName         String?   @map("middle_name") @db.VarChar(100)
  lastName           String?   @map("last_name") @db.VarChar(100)
  phone              String    @unique @db.VarChar(25)
  email              String?   @unique @db.VarChar(255)
  preferredLanguage  String    @default("en") @map("preferred_language") @db.Char(2)
  status             UserStatus @default(PENDING)
  phoneVerified      Boolean   @default(false) @map("phone_verified")
  emailVerified      Boolean   @default(false) @map("email_verified")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  credential         Credential?
  userRoles          UserRole[]
  userOrganizations  UserOrganization[]
  rolesAssigned      UserRole[]        @relation("AssignedByUser")
  permissionsGranted RolePermission[] @relation("GrantedByUser")
  farmerProfile      FarmerProfile?
  buyerOrders        Order[]           @relation("BuyerOrders")

  @@map("users")
  @@schema("identity")
}

model Credential {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String    @unique @map("user_id") @db.Uuid
  passwordHash         String?   @map("password_hash")
  passwordChangedAt    DateTime? @map("password_changed_at") @db.Timestamptz
  lastLoginAt          DateTime? @map("last_login_at") @db.Timestamptz
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts") @db.SmallInt
  lockedUntil          DateTime? @map("locked_until") @db.Timestamptz
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credentials")
  @@schema("identity")
}

model Role {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String   @unique @db.VarChar(50)
  displayName      String   @map("display_name") @db.VarChar(100)
  description      String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz

  userRoles        UserRole[]
  rolePermissions  RolePermission[]

  @@map("roles")
  @@schema("identity")
}

model Permission {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String   @unique @db.VarChar(100)
  displayName      String   @map("display_name") @db.VarChar(150)
  description      String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz

  rolePermissions  RolePermission[]

  @@map("permissions")
  @@schema("identity")
}

model UserRole {
  userId      String   @map("user_id") @db.Uuid
  roleId      String   @map("role_id") @db.Uuid
  assignedAt  DateTime @default(now()) @map("assigned_at") @db.Timestamptz
  assignedBy  String?  @map("assigned_by") @db.Uuid

  user            User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedByUser  User? @relation("AssignedByUser", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("identity")
}

model RolePermission {
  roleId        String   @map("role_id") @db.Uuid
  permissionId  String   @map("permission_id") @db.Uuid
  grantedAt     DateTime @default(now()) @map("granted_at") @db.Timestamptz
  grantedBy     String?  @map("granted_by") @db.Uuid

  role            Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission      Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedByUser   User?       @relation("GrantedByUser", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("identity")
}

model Organization {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String    @unique @db.VarChar(50)
  name               String    @db.VarChar(255)
  description        String?
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  userOrganizations  UserOrganization[]

  @@map("organizations")
  @@schema("identity")
}

model UserOrganization {
  userId          String   @map("user_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  positionTitle   String?  @map("position_title") @db.VarChar(100)
  joinedAt        DateTime @default(now()) @map("joined_at") @db.Timestamptz
  isPrimary       Boolean  @default(false) @map("is_primary")

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
  @@map("user_organizations")
  @@schema("identity")
}

model OtpCode {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone      String   @db.VarChar(25)
  code       String   @db.VarChar(6)
  used       Boolean  @default(false)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([phone])
  @@map("otp_codes")
  @@schema("identity")
}

// ============================================================================
// Catalog module (Phase 2–3)
// Maps database/migrations/catalog/001..008_catalog_*.sql
// ============================================================================

model Category {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String    @unique @db.VarChar(50)
  nameEn        String    @map("name_en") @db.VarChar(100)
  nameAm        String    @map("name_am") @db.VarChar(100)
  descriptionEn String?   @map("description_en")
  descriptionAm String?   @map("description_am")
  isActive      Boolean   @default(false) @map("is_active")
  sortOrder     Int       @default(0) @map("sort_order") @db.SmallInt
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  products      Product[]
  listings      Listing[]

  @@index([isActive])
  @@map("categories")
  @@schema("catalog")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  COMING_SOON
  DISCONTINUED

  @@schema("catalog")
  @@map("product_status")
}

model Unit {
  code      String    @id @db.VarChar(20)
  nameEn    String    @map("name_en") @db.VarChar(50)
  nameAm    String    @map("name_am") @db.VarChar(50)
  dimension String    @db.VarChar(20)
  sortOrder Int       @default(0) @map("sort_order") @db.SmallInt

  products          Product[]
  conversionsFrom   UnitConversion[] @relation("ConversionFrom")
  conversionsTo     UnitConversion[] @relation("ConversionTo")
  stockLots         StockLot[]
  stockMovements    StockMovement[]
  reservations      Reservation[]
  storageSites      StorageSite[]

  @@map("units")
  @@schema("catalog")
}

model UnitConversion {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fromUnitCode String  @map("from_unit_code") @db.VarChar(20)
  toUnitCode   String  @map("to_unit_code") @db.VarChar(20)
  factor       Decimal @db.Decimal(18, 6)

  fromUnit     Unit    @relation("ConversionFrom", fields: [fromUnitCode], references: [code], onDelete: Restrict)
  toUnit       Unit    @relation("ConversionTo", fields: [toUnitCode], references: [code], onDelete: Restrict)

  @@unique([fromUnitCode, toUnitCode])
  @@map("unit_conversions")
  @@schema("catalog")
}

model Product {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId       String        @map("category_id") @db.Uuid
  code             String        @unique @db.VarChar(80)
  nameEn           String        @map("name_en") @db.VarChar(150)
  nameAm           String        @map("name_am") @db.VarChar(150)
  descriptionEn    String?       @map("description_en")
  descriptionAm    String?       @map("description_am")
  defaultUnitCode  String        @map("default_unit_code") @db.VarChar(20)
  status           ProductStatus @default(INACTIVE)
  isDefault        Boolean       @default(false) @map("is_default")
  sortOrder        Int           @default(0) @map("sort_order") @db.SmallInt
  attributesSchema Json?         @map("attributes_schema")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime      @default(now()) @map("updated_at") @db.Timestamptz

  category         Category           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  defaultUnit      Unit               @relation(fields: [defaultUnitCode], references: [code], onDelete: Restrict)
  varieties        ProductVariety[]
  translations     ProductTranslation[]
  listings         Listing[]
  stockLots        StockLot[]

  @@index([categoryId])
  @@index([status])
  @@map("products")
  @@schema("catalog")
}

model ProductVariety {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  code      String   @db.VarChar(80)
  nameEn    String   @map("name_en") @db.VarChar(150)
  nameAm    String   @map("name_am") @db.VarChar(150)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockLots StockLot[]

  @@unique([productId, code])
  @@index([productId])
  @@map("product_varieties")
  @@schema("catalog")
}

model ProductTranslation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  locale      String   @db.VarChar(15)
  name        String   @db.VarChar(150)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([locale])
  @@map("product_translations")
  @@schema("catalog")
}

// ============================================================================
// Marketplace module (Package 003)
// Maps database/migrations/marketplace/001..004_marketplace_*.sql
// ============================================================================

enum ProcessMethod {
  WASHED
  NATURAL
  HONEY
  SEMI_WASHED
  HULLED
  ANAEROBIC
  CARBONIC_MACERATION

  @@schema("marketplace")
  @@map("process_method")
}

enum CoffeeGrade {
  GRADE_1
  GRADE_2
  GRADE_3
  GRADE_4
  GRADE_5
  GRADE_6
  GRADE_7
  GRADE_8
  GRADE_9
  GRADE_UNKNOWN

  @@schema("marketplace")
  @@map("coffee_grade")
}

enum ListingStatus {
  ACTIVE
  RESERVED
  SOLD
  CANCELLED

  @@schema("marketplace")
  @@map("listing_status")
}

model Cooperative {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String    @db.VarChar(200)
  unionName      String?   @map("union_name") @db.VarChar(200)
  region         String    @db.VarChar(100)
  zone           String?   @db.VarChar(100)
  licenseNumber  String?   @map("license_number") @db.VarChar(50)
  verified       Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  farmerProfiles   FarmerProfile[]
  farms            Farm[]
  farmParties      FarmParty[]
  storageSites     StorageSite[]
  warehouseParties WarehouseParty[]

  @@map("cooperatives")
  @@schema("marketplace")
}

model FarmerProfile {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String    @unique @map("user_id") @db.Uuid
  cooperativeId      String?   @map("cooperative_id") @db.Uuid
  region             String    @db.VarChar(100)
  zone               String?   @db.VarChar(100)
  woreda             String?   @db.VarChar(100)
  altitudeM          Decimal?  @map("altitude_m") @db.Decimal(6, 1)
  farmSizeHa         Decimal?  @map("farm_size_ha") @db.Decimal(6, 2)
  primaryLanguage    String    @default("am") @map("primary_language") @db.VarChar(200)
  verified           Boolean   @default(false)
  verificationNotes  String?   @map("verification_notes") @db.VarChar(500)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cooperative        Cooperative?  @relation(fields: [cooperativeId], references: [id], onDelete: SetNull)
  listings           Listing[]
  orders             Order[]       @relation("FarmerOrders")
  farmParties        FarmParty[]
  warehouseParties   WarehouseParty[]

  @@map("farmer_profiles")
  @@schema("marketplace")
}

model Listing {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmerId       String        @map("farmer_id") @db.Uuid
  categoryId     String?       @map("category_id") @db.Uuid
  productId      String?       @map("product_id") @db.Uuid
  stockLotId     String?       @map("stock_lot_id") @db.Uuid
  farmId         String?       @map("farm_id") @db.Uuid
  region         String        @db.VarChar(100)
  regionEn       String?       @map("region_en") @db.VarChar(100)
  woreda         String?       @db.VarChar(100)
  washingStation String?       @map("washing_station") @db.VarChar(150)
  cooperative    String?       @db.VarChar(200)
  processMethod  ProcessMethod @map("process_method")
  grade          CoffeeGrade
  variety        String?       @db.VarChar(100)
  quantityKg     Decimal       @map("quantity_kg") @db.Decimal(8, 2)
  pricePerKg     Decimal       @map("price_per_kg") @db.Decimal(8, 2)
  harvestDate    DateTime      @map("harvest_date") @db.Date
  altitudeM      Decimal?      @map("altitude_m") @db.Decimal(6, 1)
  cupScore       Decimal?      @map("cup_score") @db.Decimal(4, 1)
  photoUrls      String[]      @default([]) @map("photo_urls")
  status         ListingStatus @default(ACTIVE)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @default(now()) @map("updated_at") @db.Timestamptz

  farmer         FarmerProfile @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  category       Category?     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  product        Product?      @relation(fields: [productId], references: [id], onDelete: Restrict)
  stockLot       StockLot?     @relation(fields: [stockLotId], references: [id], onDelete: SetNull)
  farm           Farm?         @relation(fields: [farmId], references: [id], onDelete: SetNull)
  orders         Order[]
  reservations   Reservation[]

  @@index([region])
  @@index([grade])
  @@index([status])
  @@index([categoryId])
  @@index([productId])
  @@index([stockLotId])
  @@index([farmId])
  @@map("listings")
  @@schema("marketplace")
}

// ============================================================================
// Orders module (Package 004)
// Maps database/migrations/orders/001..003_orders_*.sql
// ============================================================================

enum OrderStatus {
  PENDING_PAYMENT
  PAID_ESCROW
  CONFIRMED
  SHIPPED
  DELIVERED
  DISPUTED
  COMPLETED
  CANCELLED

  @@schema("orders")
  @@map("order_status")
}

enum PaymentMethod {
  TELEBIRR
  CBE_BIRR
  MPESA
  CHAPA
  SANTIMPAY

  @@schema("orders")
  @@map("payment_method")
}

model Order {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId         String        @map("listing_id") @db.Uuid
  buyerId           String        @map("buyer_id") @db.Uuid
  farmerId          String        @map("farmer_id") @db.Uuid
  quantityKg        Decimal       @map("quantity_kg") @db.Decimal(10, 2)
  totalEtb          Decimal       @map("total_etb") @db.Decimal(12, 2)
  commissionEtb     Decimal       @map("commission_etb") @db.Decimal(12, 2)
  farmerPayoutEtb   Decimal       @map("farmer_payout_etb") @db.Decimal(12, 2)
  status            OrderStatus   @default(PENDING_PAYMENT)
  paymentMethod     PaymentMethod @map("payment_method")
  paymentReference  String?       @map("payment_reference") @db.VarChar(100)
  deliveryAddress   String        @map("delivery_address") @db.VarChar(500)
  paidAt            DateTime?     @map("paid_at") @db.Timestamptz
  deliveredAt       DateTime?     @map("delivered_at") @db.Timestamptz
  completedAt       DateTime?     @map("completed_at") @db.Timestamptz
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @default(now()) @map("updated_at") @db.Timestamptz

  listing           Listing            @relation(fields: [listingId], references: [id], onDelete: Restrict)
  buyer             User               @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  farmer            FarmerProfile      @relation("FarmerOrders", fields: [farmerId], references: [id], onDelete: Restrict)
  certificate       OriginCertificate?
  reservations      Reservation[]

  @@index([buyerId])
  @@index([farmerId])
  @@index([status])
  @@map("orders")
  @@schema("orders")
}

model OriginCertificate {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId        String   @unique @map("order_id") @db.Uuid
  certNumber     String   @unique @map("cert_number") @db.VarChar(30)
  farmerName     String   @map("farmer_name") @db.VarChar(100)
  farmLocation   String   @map("farm_location") @db.VarChar(200)
  cooperative    String?  @db.VarChar(200)
  region         String?  @db.VarChar(100)
  grade          String   @db.VarChar(20)
  processMethod  String   @map("process_method") @db.VarChar(20)
  harvestDate    DateTime @map("harvest_date") @db.Date
  altitudeM      Decimal? @map("altitude_m") @db.Decimal(6, 1)
  quantityKg     Decimal? @map("quantity_kg") @db.Decimal(8, 2)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz

  order          Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("origin_certificates")
  @@schema("orders")
}

// ============================================================================
// Farms module (Phase 4.1)
// Maps database/migrations/farms/001..006_farms_*.sql
// Farms do not own catalog products — listings/cycles reference products.
// ============================================================================

enum FarmStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED

  @@schema("farms")
  @@map("farm_status")
}

enum TenureType {
  OWNED
  LEASED
  COOPERATIVE
  CUSTOMARY
  MIXED
  OTHER

  @@schema("farms")
  @@map("tenure_type")
}

enum PartyRole {
  OWNER
  CO_OWNER
  OPERATOR
  TENANT
  COOP_MANAGER
  VIEWER

  @@schema("farms")
  @@map("party_role")
}

enum ProductionUnitKind {
  GENERIC
  TREE_BLOCK
  GREENHOUSE
  PEN
  POND
  APIARY
  OTHER

  @@schema("farms")
  @@map("production_unit_kind")
}

enum FarmAuditEntityType {
  FARM
  PLOT
  FIELD
  PARTY
  PRODUCTION_UNIT

  @@schema("farms")
  @@map("audit_entity_type")
}

enum FarmAuditAction {
  CREATE
  UPDATE
  STATUS_CHANGE
  PARTY_ADD
  PARTY_END

  @@schema("farms")
  @@map("audit_action")
}

model Farm {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code              String?    @db.VarChar(40)
  name              String     @db.VarChar(150)
  nameAm            String?    @map("name_am") @db.VarChar(150)
  tenureType        TenureType @default(OWNED) @map("tenure_type")
  cooperativeId     String?    @map("cooperative_id") @db.Uuid
  status            FarmStatus @default(ACTIVE)
  region            String     @db.VarChar(100)
  regionEn          String?    @map("region_en") @db.VarChar(100)
  zone              String?    @db.VarChar(100)
  woreda            String?    @db.VarChar(100)
  kebele            String?    @db.VarChar(100)
  altitudeM         Decimal?   @map("altitude_m") @db.Decimal(6, 1)
  sizeHa            Decimal?   @map("size_ha") @db.Decimal(10, 2)
  centroidLat       Decimal?   @map("centroid_lat") @db.Decimal(9, 6)
  centroidLng       Decimal?   @map("centroid_lng") @db.Decimal(9, 6)
  boundaryGeojson   Json?      @map("boundary_geojson")
  boundarySource    String?    @map("boundary_source") @db.VarChar(40)
  boundaryUpdatedAt DateTime?  @map("boundary_updated_at") @db.Timestamptz
  notes             String?
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime   @default(now()) @map("updated_at") @db.Timestamptz

  cooperative       Cooperative?      @relation(fields: [cooperativeId], references: [id], onDelete: SetNull)
  parties           FarmParty[]
  plots             Plot[]
  productionUnits   ProductionUnit[]
  translations      FarmTranslation[]
  partyHistory      FarmPartyHistory[]
  auditLogs         FarmAuditLog[]
  stockLots         StockLot[]
  storageSites      StorageSite[]
  listings          Listing[]

  @@index([status])
  @@index([cooperativeId])
  @@map("farms")
  @@schema("farms")
}

model FarmParty {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmId          String      @map("farm_id") @db.Uuid
  farmerProfileId String?     @map("farmer_profile_id") @db.Uuid
  cooperativeId   String?     @map("cooperative_id") @db.Uuid
  partyRole       PartyRole   @map("party_role")
  tenureType      TenureType? @map("tenure_type")
  isPrimary       Boolean     @default(false) @map("is_primary")
  validFrom       DateTime?   @map("valid_from") @db.Date
  validTo         DateTime?   @map("valid_to") @db.Date
  status          FarmStatus  @default(ACTIVE)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime    @default(now()) @map("updated_at") @db.Timestamptz

  farm            Farm           @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmerProfile   FarmerProfile? @relation(fields: [farmerProfileId], references: [id], onDelete: Cascade)
  cooperative     Cooperative?   @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)

  @@index([farmId])
  @@index([farmerProfileId])
  @@map("farm_parties")
  @@schema("farms")
}

model Plot {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmId            String      @map("farm_id") @db.Uuid
  code              String?     @db.VarChar(40)
  name              String      @db.VarChar(150)
  nameAm            String?     @map("name_am") @db.VarChar(150)
  tenureType        TenureType? @map("tenure_type")
  status            FarmStatus  @default(ACTIVE)
  sizeHa            Decimal?    @map("size_ha") @db.Decimal(10, 2)
  centroidLat       Decimal?    @map("centroid_lat") @db.Decimal(9, 6)
  centroidLng       Decimal?    @map("centroid_lng") @db.Decimal(9, 6)
  boundaryGeojson   Json?       @map("boundary_geojson")
  boundarySource    String?     @map("boundary_source") @db.VarChar(40)
  boundaryUpdatedAt DateTime?   @map("boundary_updated_at") @db.Timestamptz
  notes             String?
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime    @default(now()) @map("updated_at") @db.Timestamptz

  farm              Farm             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fields            Field[]
  productionUnits   ProductionUnit[]
  stockLots         StockLot[]

  @@index([farmId])
  @@map("plots")
  @@schema("farms")
}

model Field {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  plotId            String     @map("plot_id") @db.Uuid
  code              String?    @db.VarChar(40)

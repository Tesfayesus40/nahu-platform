enum WarehouseSiteType {
  ON_FARM
  COOPERATIVE
  NAHU
  THIRD_PARTY

  @@schema("warehouse")
  @@map("site_type")
}

enum WarehouseSiteStatus {
  ACTIVE
  INACTIVE

  @@schema("warehouse")
  @@map("site_status")
}

enum WarehousePartyRole {
  OWNER
  MANAGER
  VIEWER

  @@schema("warehouse")
  @@map("party_role")
}

enum WarehousePartyStatus {
  ACTIVE
  INACTIVE

  @@schema("warehouse")
  @@map("party_status")
}

model StorageSite {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String?             @db.VarChar(40)
  name             String              @db.VarChar(150)
  nameAm           String?             @map("name_am") @db.VarChar(150)
  siteType         WarehouseSiteType   @map("site_type")
  status           WarehouseSiteStatus @default(ACTIVE)
  farmId           String?             @map("farm_id") @db.Uuid
  cooperativeId    String?             @map("cooperative_id") @db.Uuid
  region           String?             @db.VarChar(100)
  regionEn         String?             @map("region_en") @db.VarChar(100)
  zone             String?             @db.VarChar(100)
  woreda           String?             @db.VarChar(100)
  kebele           String?             @db.VarChar(100)
  centroidLat      Decimal?            @map("centroid_lat") @db.Decimal(10, 7)
  centroidLng      Decimal?            @map("centroid_lng") @db.Decimal(10, 7)
  capacity         Decimal?            @db.Decimal(14, 3)
  capacityUnitCode String?             @map("capacity_unit_code") @db.VarChar(20)
  notes            String?
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime            @default(now()) @map("updated_at") @db.Timestamptz

  farm             Farm?               @relation(fields: [farmId], references: [id], onDelete: Restrict)
  cooperative      Cooperative?        @relation(fields: [cooperativeId], references: [id], onDelete: SetNull)
  capacityUnit     Unit?               @relation(fields: [capacityUnitCode], references: [code], onDelete: Restrict)
  parties          WarehouseParty[]
  zones            StorageZone[]
  stockLots        StockLot[]
  movementsFrom    StockMovement[]     @relation("MovementFromSite")
  movementsTo      StockMovement[]     @relation("MovementToSite")

  @@index([farmId])
  @@index([status])
  @@index([siteType])
  @@map("storage_sites")
  @@schema("warehouse")
}

model WarehouseParty {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storageSiteId   String                @map("storage_site_id") @db.Uuid
  farmerProfileId String?               @map("farmer_profile_id") @db.Uuid
  cooperativeId   String?               @map("cooperative_id") @db.Uuid
  partyRole       WarehousePartyRole    @map("party_role")
  isPrimary       Boolean               @default(false) @map("is_primary")
  status          WarehousePartyStatus  @default(ACTIVE)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime              @default(now()) @map("updated_at") @db.Timestamptz

  storageSite     StorageSite           @relation(fields: [storageSiteId], references: [id], onDelete: Cascade)
  farmerProfile   FarmerProfile?        @relation(fields: [farmerProfileId], references: [id], onDelete: Cascade)
  cooperative     Cooperative?          @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)

  @@index([storageSiteId])
  @@index([farmerProfileId])
  @@map("warehouse_parties")
  @@schema("warehouse")
}

model StorageZone {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storageSiteId String              @map("storage_site_id") @db.Uuid
  code          String?             @db.VarChar(40)
  name          String              @db.VarChar(150)
  status        WarehouseSiteStatus @default(ACTIVE)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime            @default(now()) @map("updated_at") @db.Timestamptz

  storageSite   StorageSite         @relation(fields: [storageSiteId], references: [id], onDelete: Cascade)

  @@index([storageSiteId])
  @@map("storage_zones")
  @@schema("warehouse")
}

enum ReservationStatus {
  ACTIVE
  ORDER_HELD
  RELEASED
  CONSUMED
  ALLOCATED
  DISPATCHED

  @@schema("inventory")
  @@map("reservation_status")
}

model Reservation {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lotId     String            @map("lot_id") @db.Uuid
  listingId String?           @map("listing_id") @db.Uuid
  orderId   String?           @map("order_id") @db.Uuid
  qty       Decimal           @db.Decimal(14, 3)
  unitCode  String            @map("unit_code") @db.VarChar(20)
  status    ReservationStatus @default(ACTIVE)
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime          @default(now()) @map("updated_at") @db.Timestamptz

  lot       StockLot          @relation(fields: [lotId], references: [id], onDelete: Restrict)
  unit      Unit              @relation(fields: [unitCode], references: [code], onDelete: Restrict)
  listing   Listing?          @relation(fields: [listingId], references: [id], onDelete: SetNull)
  order     Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([lotId])
  @@index([listingId])
  @@index([orderId])
  @@map("reservations")
  @@schema("inventory")
}

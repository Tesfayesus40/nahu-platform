}

model FarmAuditLog {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType  FarmAuditEntityType @map("entity_type")
  entityId    String              @map("entity_id") @db.Uuid
  farmId      String              @map("farm_id") @db.Uuid

  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "postinstall": "prisma generate",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:catalog-rules": "node --test src/catalog/product-resolve.rules.test.mjs",
    "test:farms-rules": "node --test src/farms/farms.rules.test.mjs",
    "test:inventory-rules": "node --test src/inventory/inventory.rules.test.mjs",
    "test:warehouse-rules": "node --test src/warehouse/warehouse.rules.test.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:reset-staging": "node scripts/reset-test-data.mjs",
    "db:dump-staging": "node scripts/dump-staging-data.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "africastalking": "^0.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.2.0",
    "multer": "^2.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^10.4.9",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.2",
    "eslint": "^10.7.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0"
  }
}
